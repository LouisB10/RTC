# Connexion Postgres (voir docker-compose.yml à la racine, exposé sur le port hôte 5433).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
DATABASE_URL="postgresql://rtc:rtc@localhost:5433/rtc?schema=public"

# Port du serveur (3000 est pris par le client Next).
PORT=3001

# Better Auth. Générer le secret avec: openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3001"
